  "keyFeatures": [
    "Dynamic JSONB product metadata with category-based validation",
    "Vertical Slice Architecture for feature isolation",
    "Hybrid data access with EF Core and Dapper",
    "Recursive category hierarchy with attribute inheritance",
    "PostgreSQL JSONB optimized queries with LATERAL joins",
    "Schema-driven validation and normalization pipeline",
    "Automatic SKU generation",
    "Soft deletion with global query filters"
  ],
  "publicApiSurface": [
    "POST /api/v1/admin/products",
    "PUT /api/v1/admin/products/{id}",
    "DELETE /api/v1/admin/products/{id}",
    "GET /api/v1/admin/products",
    "GET /api/v1/admin/categories",
    "GET /api/v1/admin/categories/{categoryId}/metadata"
  ]
